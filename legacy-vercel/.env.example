# Legacy Properties — Vercel environment variables
# Copy this file into Vercel → Project → Settings → Environment Variables.
# DO NOT commit a populated copy of this file to git.

# ──────────── Supabase (Phase 1A) ────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ──────────── Anthropic (Phase 1C — direct API only) ────────────
# Endpoint used by api/_lib/anthropic.js → https://api.anthropic.com/v1/messages
# Default model: claude-sonnet-4-6
ANTHROPIC_API_KEY=

# ──────────── Twilio (Phase 1C alert + Phase 1D send) ────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ──────────── Email (Resend — primary; SendGrid optional fallback) ────────────

# Resend (recommended)
# Get key at https://resend.com/api-keys
# Send from onboarding@resend.dev while testing (Resend sandbox sender,
# can only deliver to the verified address on your Resend account).
# Once legacycalifornia.com is verified in Resend, switch to a domain sender
# like sara@legacycalifornia.com.
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=Sara Cooper · Legacy Properties
RESEND_REPLY_TO=SaraSellsCalifornia@gmail.com

# SendGrid (optional fallback — used if RESEND_API_KEY is not set)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=sara@legacycalifornia.com
SENDGRID_FROM_NAME=Sara Cooper · Legacy Properties
SENDGRID_REPLY_TO=SaraSellsCalifornia@gmail.com

# ──────────── Follow Up Boss (Phase 1H — temporary; removed January) ────────────
FUB_API_KEY=

# ──────────── MetroListPRO Optima IDX (Phase 1I) ────────────
IHOMEFINDER_API_KEY=

# ──────────── MetroList RESO Web API (already wired in api/_metrolist.js) ────────────
METROLIST_CLIENT_ID=
METROLIST_CLIENT_SECRET=
METROLIST_TOKEN_URL=
METROLIST_API_URL=

# ──────────── Misc ────────────
# Comma-separated list of allowed origins for browser CORS. Use * for dev.
ALLOWED_ORIGINS=*
