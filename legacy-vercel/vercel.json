{
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=900, stale-while-revalidate=1800" }
      ]
    },
    {
      "source": "/api/sequences/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/api/idx/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/api/photo",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, s-maxage=604800, immutable" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/listing",          "destination": "/listing.html" },
    { "source": "/agent",            "destination": "/agent.html" },
    { "source": "/office",           "destination": "/office.html" },
    { "source": "/market-report",    "destination": "/market-report.html" },
    { "source": "/listing-report",   "destination": "/listing-report.html" },
    { "source": "/open-home-report", "destination": "/open-home-report.html" }
  ],
  "functions": {
    "api/*.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "crons": [
    { "path": "/api/sequences/cron", "schedule": "0 14 * * *" },
    { "path": "/api/idx/sync",       "schedule": "0 18 * * *" }
  ]
}
