{
  "redirects": [
    {
      "source": "/listings",
      "destination": "/property-search.html",
      "permanent": true
    },
    {
      "source": "/listings.html",
      "destination": "/property-search.html",
      "permanent": true
    },
    {
      "source": "/open-houses",
      "destination": "/open-home-listings.html",
      "permanent": true
    },
    {
      "source": "/open-houses.html",
      "destination": "/open-home-listings.html",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=900, stale-while-revalidate=1800"
        }
      ]
    },
    {
      "source": "/api/photo",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, s-maxage=604800, immutable"
        }
      ]
    }
  ],
  "functions": {
    "api/*.js": {
      "memory": 256,
      "maxDuration": 10
    }
  }
}
